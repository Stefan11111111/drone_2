module drone
{
    module dds
    {
        @nested
        struct CartesianPosition
        {
            double x;
            double y;
            double z;
        };

        struct TargetTrack
        {
            @key unsigned long long target_id;
            CartesianPosition position;
            long long measured_at_ms;
        };

        enum DroneStatus
        {
            @value(0)
            DRONE_AVAILABLE,
            @value(1)
            DRONE_ASSIGNED,
            @value(2)
            DRONE_INTERCEPTING,
            @value(3)
            DRONE_INTERCEPTION_SUCCEEDED,
            @value(4)
            DRONE_INTERCEPTION_FAILED
        };

        struct DroneState
        {
            @key unsigned long long drone_id;
            CartesianPosition position;
            long long reported_at_ms;
            DroneStatus status;
            @optional unsigned long long assigned_target_id;
        };

        struct Assignment
        {
            @key unsigned long long drone_id;
            unsigned long long target_id;
        };

        struct InterceptionCommand
        {
            @key unsigned long long command_id;
            unsigned long long drone_id;
            unsigned long long target_id;
        };

        struct ExplosionEvent
        {
            @key unsigned long long event_id;
            unsigned long long drone_id;
            unsigned long long target_id;
            CartesianPosition position;
            long long occurred_at_ms;
        };
    };
};
